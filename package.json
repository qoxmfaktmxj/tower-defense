{
  "name": "tower-defense",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:web": "corepack pnpm --filter @tower-defense/web dev",
    "dev:api": "corepack pnpm --filter @tower-defense/api dev",
    "build": "corepack pnpm --filter @tower-defense/shared build && corepack pnpm --filter @tower-defense/game build && corepack pnpm --filter @tower-defense/api build && corepack pnpm --filter @tower-defense/web build",
    "typecheck": "corepack pnpm -r typecheck",
    "test": "node --import tsx --test tests/index.test.ts",
    "lint": "corepack pnpm run typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
